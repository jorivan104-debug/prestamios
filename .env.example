# Copia a `.env` o `.env.local` para autenticación y datos vía **API local** (SQLite + JWT).
# Con `VITE_USE_API` no true o sin definir, la app en modo **demo** (localStorage) sin login.

# Activar el cliente REST: ejecuta en paralelo `node server/index.mjs` o `npm run dev:all`
VITE_USE_API=true

# Base de la API (normalmente vacío en dev: Vite hace proxy de `/api` a http://127.0.0.1:3847)
VITE_API_BASE=

# Servidor: fichero de base (opcional)
# DATABASE_PATH=./server/data/prestamos.sqlite
# JWT_SECRET=cambia-esto-en-producción
# PORT=3847
